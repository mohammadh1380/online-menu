# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=coffee_menu

# ── FastAPI ────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production
SECRET_KEY=replace-with-a-random-secret-key-min-32-chars

# Admin credentials (single admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password

# Token expiry in minutes (default 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Max upload size in MB
MAX_FILE_SIZE_MB=5

# ── Frontend ───────────────────────────────────────────────────────────────────
# Public-facing URL of the backend (used by the browser, not Docker network)
# Change to your domain/IP in production, e.g. https://api.mycafe.com
NEXT_PUBLIC_API_URL=http://localhost:8000
